{
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun .claude/hooks/block-sensitive-files.js",
            "statusMessage": "민감 파일 접근 검사 중..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "bun run test",
            "statusMessage": "커밋 전 테스트 실행 중...",
            "timeout": 120
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "bash .claude/hooks/check-test.sh",
            "statusMessage": "TDD 규칙 검사 중..."
          }
        ]
      }
    ]
  }
}
